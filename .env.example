# sb-easy Configuration
# Copy to .env and customize

# HTTP binding
BIND_ADDR=0.0.0.0:8000
DATABASE_URL=sqlite:/app/data/sb-easy.db?mode=rwc

# Auth
JWT_SECRET=change-me-to-a-random-string
ADMIN_PASSWORD=admin

# Legacy global agent token. Per-host tokens (created automatically with each
# Host in the panel) are now preferred — see agent/.env.example. This global
# token still works and maps to the built-in `self` host for backward
# compatibility; if empty, only per-host tokens are accepted.
AGENT_TOKEN=

# CORS allowlist (comma-separated origins). Empty or "*" = permissive (dev only).
# CORS_ORIGINS=https://panel.example.com

# WireGuard
# NAT masquerade + forwarding are configured internally from these values; the
# egress interface is auto-detected from the default route (override below).
WG_INTERFACE=wg0
WG_PORT=51820
WG_ADDRESS=10.59.32.1/24
WG_DNS=10.59.32.1
WG_MTU=1420
# WG_EGRESS=eth0

# Sing-box connection (Clash API). Use a local/private address.
SINGBOX_API_URL=http://127.0.0.1:9090
SINGBOX_API_SECRET=

# External hostname (used as Endpoint in client configs)
EXTERNAL_HOSTNAME=vpn.example.com

# Agent config hash seed (auto-generated if not set)
# CONFIG_HASH_SEED=

# ── Built-in `self` host sing-box management (two mutually-exclusive modes) ──
#
# Mode 1 — sb-easy supervises sing-box as a child process (recommended; you run
# and manage ONLY sb-easy, no separate sing-box service). Enable with:
# SINGBOX_MANAGED=true
# SINGBOX_BIN=sing-box                         # path to the sing-box binary
# SELF_SINGBOX_CONFIG_PATH=data/sing-box.gen.json   # where the config is written
# SELF_SINGBOX_INTERVAL=10                     # config poll seconds (min 2)
#
# Mode 2 — sb-easy writes the config and triggers an EXTERNAL reload (e.g. your
# own systemd sing-box). Used only when SINGBOX_MANAGED is not true:
# SELF_SINGBOX_CONFIG_PATH=/etc/sing-box/config.d/90-generated.json
# SELF_RELOAD_CMD=sudo systemctl reload sing-box
# SELF_SINGBOX_INTERVAL=10

# Logging
RUST_LOG=info
