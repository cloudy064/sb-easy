# sb-easy Configuration
# Copy to .env and customize

# HTTP binding
BIND_ADDR=0.0.0.0:8000
DATABASE_URL=sqlite:/app/data/sb-easy.db?mode=rwc

# Auth
JWT_SECRET=change-me-to-a-random-string
ADMIN_PASSWORD=admin

# WireGuard
WG_INTERFACE=wg0
WG_PORT=51820
WG_ADDRESS=10.59.32.1/24
WG_DNS=10.59.32.1
WG_MTU=1420
WG_POST_UP=iptables -t nat -A POSTROUTING -s 10.59.32.0/24 -o eth0 -j MASQUERADE; iptables -A FORWARD -i wg0 -j ACCEPT; iptables -A FORWARD -o wg0 -j ACCEPT
WG_POST_DOWN=iptables -t nat -D POSTROUTING -s 10.59.32.0/24 -o eth0 -j MASQUERADE; iptables -D FORWARD -i wg0 -j ACCEPT; iptables -D FORWARD -o wg0 -j ACCEPT

# Sing-box connection
SINGBOX_API_URL=http://10.168.1.5:9090
SINGBOX_API_SECRET=

# External hostname (for client config generation)
EXTERNAL_HOSTNAME=39.108.98.208

# Agent config hash seed (auto-generated if not set)
# CONFIG_HASH_SEED=

# Logging
RUST_LOG=info
