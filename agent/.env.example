# Managed-node config for `sb-easy agent`
#
# A managed node runs the SAME sb-easy binary in agent mode:
#     sb-easy agent
# It connects to the panel, pulls this host's config, and supervises sing-box
# in process (spawn / reload / respawn) — only one thing to run on the node.
# (The standalone `sb-easy-agent` binary is deprecated; prefer `sb-easy agent`.)

# URL of the sb-easy panel/server.
SB_EASY_SERVER=http://panel.example.com:51821

# This host's per-host agent token. Panel → Hosts → <host> → Install.
AGENT_TOKEN=

# sing-box binary this node supervises, and where its config is written.
SINGBOX_BIN=sing-box
SINGBOX_CONFIG_PATH=data/sing-box.gen.json

# How often (seconds) to poll the panel for config/commands. Min 2. Default 10.
AGENT_INTERVAL=10

# Logging
RUST_LOG=info
