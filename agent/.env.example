# sb-easy-agent configuration
# Copy to .env next to the agent binary, or pass these as environment variables.

# URL of the sb-easy panel/server.
SB_EASY_SERVER=http://panel.example.com:51821

# This host's per-host agent token. Get it from the panel: Hosts → <host> →
# Install. The server rejects unauthenticated config requests (401).
AGENT_TOKEN=

# How often (seconds) to poll for config changes. Shorter = lower latency when
# you change this host's config in the panel; there is no server push, so this
# interval is the upper bound on how stale the config can be. Min 2s. Default 10.
AGENT_INTERVAL=10

# Where to write the sing-box config this host should run.
SINGBOX_CONFIG_PATH=/etc/sing-box/config.d/90-generated.json

# Command run after a new config is written.
RELOAD_CMD=sudo systemctl reload sing-box

# Logging
RUST_LOG=info
